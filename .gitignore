# ==============================================================================
# AeroShield — Root Git Ignore
# ==============================================================================

# OS / System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDEs, Editors and Tooling
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
.project
.classpath
.settings/
.recommenders/
*.sublime-project
*.sublime-workspace

# Claude Code
.claude/

# Environment / Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.pem
*.key

# Database Volumes
postgres_data/
pgadmin_data/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==============================================================================
# Backend (Python / FastAPI)
# ==============================================================================
backend/venv/
backend/.venv/
backend/env/
backend/ENV/
backend/env.bak/
backend/venv.bak/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/**/*.pyd
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/
backend/htmlcov/
backend/build/
backend/dist/
backend/*.egg-info/
backend/db.sqlite3
backend/db.sqlite3-journal

# ==============================================================================
# Frontend (Next.js / React)
# ==============================================================================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/
frontend/coverage/
frontend/.vercel/
frontend/*.tsbuildinfo
frontend/next-env.d.ts
frontend/.pnp/
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions
